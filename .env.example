# Postgres connection string. Free options: Neon (neon.tech) or Supabase (supabase.com).
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Optional — only needed if you want email notifications when a lead/application comes in.
# Get a key at resend.com (free tier is generous for this volume).
RESEND_API_KEY=""
LEAD_NOTIFICATION_EMAIL="hello@craftsmanondemand.com"
