// PHASE 2 — MARKETPLACE SCHEMA REFERENCE (not active)
//
// This is the target schema for when the full marketplace (accounts, bidding,
// escrow payments, reviews) goes live — once the LLC, Stripe Connect platform
// account, and Checkr integration are in place (see ROADMAP.md).
//
// Today's live schema (prisma/schema.prisma) only has Lead and
// CraftsmanApplication. When Phase 2 starts, the plan is:
//   1. Add these models alongside the existing ones (don't delete Lead /
//      CraftsmanApplication — migrate their rows into User / JobPost once
//      real accounts exist).
//   2. Run a migration, not a fresh schema — preserve the leads collected
//      during Phase 1.
//
// Note the two fields that didn't exist in the original spec and matter a
// lot given Texas law: `licenseNumber` / `licenseVerifiedAt` on
// CraftsmanProfile, and `requiresLicense` on JobPost's category. Electrical
// and plumbing bids should be blocked at the database/application layer
// until a craftsman has a verified license on file — see the DFW compliance
// notes in ROADMAP.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  CONSUMER
  CRAFTSMAN
  ADMIN
}

enum BackgroundCheckStatus {
  NOT_STARTED
  PENDING
  APPROVED
  REJECTED
}

enum JobStatus {
  OPEN
  BIDDING
  AWARDED
  COMPLETE
  CANCELLED
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum DestinationFeeStatus {
  NOT_REQUESTED
  REQUESTED
  PAID
  REFUNDED
}

enum TransactionType {
  DESTINATION_FEE
  JOB_PAYMENT
  REFUND
  PAYOUT
}

enum TransactionStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String
  fullName        String
  phone           String?
  userType        UserType
  stripeAccountId String? // Stripe Connect connected account id (craftsmen only)
  createdAt       DateTime @default(now())

  craftsmanProfile CraftsmanProfile?
  jobPosts         JobPost[]          @relation("ConsumerJobs")
  reviewsGiven     Review[]           @relation("ReviewAuthor")
  notifications    Notification[]
  devices          Device[]
}

model CraftsmanProfile {
  id                    String                 @id @default(cuid())
  userId                String                 @unique
  user                  User                   @relation(fields: [userId], references: [id])
  businessName          String?
  headline              String?
  description           String?
  zipcode               String
  lat                   Float?
  lng                   Float?
  isVerified            Boolean                @default(false) // identity/background check
  backgroundCheckStatus BackgroundCheckStatus   @default(NOT_STARTED)
  // Licensed-trade verification — separate from identity verification above.
  // A craftsman can be `isVerified` (background-checked) without having a
  // license on file. Bids on jobs where `requiresLicense` is true on the
  // service category must be blocked unless licenseVerifiedAt is set.
  licenseNumber         String?
  licenseVerifiedAt     DateTime?
  averageRating         Float                  @default(0)
  totalReviews          Int                    @default(0)
  createdAt             DateTime               @default(now())

  portfolioImages PortfolioImage[]
  bids            Bid[]
  reviews         Review[]          @relation("ReviewedCraftsman")
}

model PortfolioImage {
  id           String           @id @default(cuid())
  craftsmanId  String
  craftsman    CraftsmanProfile @relation(fields: [craftsmanId], references: [id])
  imageUrl     String
  caption      String?
  displayOrder Int              @default(0)
}

model ServiceCategory {
  slug            String    @id // matches the slugs in src/lib/services.ts
  name            String
  requiresLicense Boolean   @default(false)
  jobPosts        JobPost[]
}

model JobPost {
  id              String          @id @default(cuid())
  consumerId      String
  consumer        User            @relation("ConsumerJobs", fields: [consumerId], references: [id])
  title           String
  description     String
  categorySlug    String
  category        ServiceCategory @relation(fields: [categorySlug], references: [slug])
  zipcode         String
  lat             Float?
  lng             Float?
  preferredDate   DateTime?
  preferredTime   String?
  budgetRangeMin  Int?
  budgetRangeMax  Int?
  status          JobStatus       @default(OPEN)
  createdAt       DateTime        @default(now())

  bids    Bid[]
  reviews Review[]
}

model Bid {
  id                      String                @id @default(cuid())
  jobPostId               String
  jobPost                 JobPost               @relation(fields: [jobPostId], references: [id])
  craftsmanId             String
  craftsman               CraftsmanProfile      @relation(fields: [craftsmanId], references: [id])
  quotedPrice             Int
  estimatedDays           Int?
  notes                   String?
  destinationFeeRequested Boolean               @default(false)
  destinationFeeStatus    DestinationFeeStatus  @default(NOT_REQUESTED)
  status                  BidStatus             @default(PENDING)
  createdAt               DateTime              @default(now())

  transactions Transaction[]
}

model Transaction {
  id                    String            @id @default(cuid())
  bidId                 String
  bid                   Bid               @relation(fields: [bidId], references: [id])
  consumerId            String
  craftsmanId           String
  amount                Int // cents
  type                  TransactionType
  status                TransactionStatus @default(PENDING)
  stripePaymentIntentId String?
  createdAt             DateTime          @default(now())
}

model Review {
  id          String           @id @default(cuid())
  jobPostId   String
  jobPost     JobPost          @relation(fields: [jobPostId], references: [id])
  reviewerId  String
  reviewer    User             @relation("ReviewAuthor", fields: [reviewerId], references: [id])
  craftsmanId String
  craftsman   CraftsmanProfile @relation("ReviewedCraftsman", fields: [craftsmanId], references: [id])
  rating      Int
  comment     String?
  createdAt   DateTime         @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  body      String
  data      Json?
  read      Boolean  @default(false)
  type      String
  createdAt DateTime @default(now())
}

model Device {
  id         String @id @default(cuid())
  userId     String
  user       User   @relation(fields: [userId], references: [id])
  fcmToken   String
  deviceType String
}
